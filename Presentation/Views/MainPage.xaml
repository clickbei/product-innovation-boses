<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BosesApp.Presentation.ViewModels"
             x:Class="BosesApp.Presentation.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Boses - Voice Assistant"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="20">

        <!-- Header Section -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,20,0,20">
            <Label Text="🎤 Boses"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"/>

            <Label Text="{Binding CurrentUserName, StringFormat='Welcome, {0}'}"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="#7F8C8D"/>

            <Label Text="{Binding StatusMessage}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#3498DB"
                   FontAttributes="Italic"/>
        </VerticalStackLayout>

        <!-- Conversation History -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                Stroke="#E0E0E0"
                StrokeThickness="1"
                Margin="0,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15"/>
            </Border.StrokeShape>

            <CollectionView ItemsSource="{Binding ConversationHistory}"
                           Margin="15">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConversationMessage">
                        <Grid Padding="0,5" ColumnDefinitions="Auto,*">
                            <BoxView Grid.Column="0"
                                    WidthRequest="4"
                                    HeightRequest="40"
                                    VerticalOptions="Start"
                                    Margin="0,5,10,0">
                                <BoxView.Color>
                                    <Binding Path="IsUser">
                                        <Binding.Converter>
                                            <vm:BoolToColorConverter TrueColor="#3498DB" FalseColor="#2ECC71"/>
                                        </Binding.Converter>
                                    </Binding>
                                </BoxView.Color>
                            </BoxView>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="{Binding Sender}"
                                      FontSize="12"
                                      FontAttributes="Bold"
                                      TextColor="#2C3E50"/>
                                <Label Text="{Binding Message}"
                                      FontSize="14"
                                      TextColor="#34495E"
                                      LineBreakMode="WordWrap"/>
                                <Label Text="{Binding Timestamp, StringFormat='{0:hh:mm tt}'}"
                                      FontSize="10"
                                      TextColor="#95A5A6"/>
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Spacing="10">
                        <Label Text="👋"
                              FontSize="48"
                              HorizontalOptions="Center"/>
                        <Label Text="Start a conversation"
                              FontSize="16"
                              TextColor="#95A5A6"
                              HorizontalOptions="Center"/>
                        <Label Text="Tap the microphone button below"
                              FontSize="12"
                              TextColor="#BDC3C7"
                              HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Border>

        <!-- Quick Action Buttons -->
        <HorizontalStackLayout Grid.Row="2"
                              Spacing="10"
                              HorizontalOptions="Center"
                              Margin="0,15">
            <Button Text="Balance"
                   Command="{Binding SimulateVoiceInputCommand}"
                   CommandParameter="Magkano ang balance ko?"
                   BackgroundColor="#3498DB"
                   TextColor="White"
                   CornerRadius="20"
                   Padding="20,10"/>

            <Button Text="Transactions"
                   Command="{Binding SimulateVoiceInputCommand}"
                   CommandParameter="Ano ang mga recent transactions ko?"
                   BackgroundColor="#9B59B6"
                   TextColor="White"
                   CornerRadius="20"
                   Padding="20,10"/>

            <Button Text="PWD Discount"
                   Command="{Binding SimulateVoiceInputCommand}"
                   CommandParameter="Calculate PWD discount for 1000 pesos medicine"
                   BackgroundColor="#E67E22"
                   TextColor="White"
                   CornerRadius="20"
                   Padding="20,10"/>
        </HorizontalStackLayout>

        <!-- Main Voice Button -->
        <Grid Grid.Row="3" Margin="0,20,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Clear Button -->
            <Button Grid.Column="0"
                   Text="Clear"
                   Command="{Binding ClearConversationCommand}"
                   BackgroundColor="#E74C3C"
                   TextColor="White"
                   CornerRadius="25"
                   WidthRequest="100"
                   HeightRequest="50"
                   HorizontalOptions="End"
                   Margin="0,0,10,0"/>

            <!-- Voice Button -->
            <Border Grid.Column="1"
                   WidthRequest="100"
                   HeightRequest="100"
                   BackgroundColor="#2ECC71"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="50"/>
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleListeningCommand}"/>
                </Border.GestureRecognizers>

                <Label FontSize="48"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Label.Text>
                        <Binding Path="IsListening">
                            <Binding.Converter>
                                <vm:BoolToTextConverter TrueText="⏹️" FalseText="🎤"/>
                            </Binding.Converter>
                        </Binding>
                    </Label.Text>
                </Label>

                <!-- Listening Animation -->
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                Binding="{Binding IsListening}"
                                Value="True">
                        <Setter Property="BackgroundColor" Value="#E74C3C"/>
                    </DataTrigger>
                </Border.Triggers>
            </Border>

            <!-- Settings Button -->
            <Button Grid.Column="2"
                   Text="⚙️"
                   Command="{Binding ToggleSimulationModeCommand}"
                   BackgroundColor="#95A5A6"
                   TextColor="White"
                   CornerRadius="25"
                   WidthRequest="100"
                   HeightRequest="50"
                   FontSize="24"
                   HorizontalOptions="Start"
                   Margin="10,0,0,0"/>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="4"
             BackgroundColor="#80000000"
             IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                             Color="White"
                             WidthRequest="60"
                             HeightRequest="60"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"/>
        </Grid>
    </Grid>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BosesApp.Presentation.ViewModels"
             x:Class="BosesApp.Presentation.Views.OnboardingPage"
             x:DataType="vm:OnboardingViewModel"
             Title="Welcome to Boses"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,20,0,20">
            <Label Text="🎤 Boses"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2ECC71"/>

            <Label Text="Voice-First Accessibility Platform"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#7F8C8D"/>
        </VerticalStackLayout>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20">

                <!-- Step 0: Can you see? -->
                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        Padding="30"
                        IsVisible="{Binding CurrentStep, Converter={StaticResource EqualToConverter}, ConverterParameter=0}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="20">
                        <Label Text="👁️ Can you see this screen?"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"
                               HorizontalOptions="Center"/>

                        <Label Text="Tap anywhere if you can see"
                               FontSize="16"
                               TextColor="#7F8C8D"
                               HorizontalOptions="Center"/>

                        <Button Text="✓ Yes, I can see"
                               Command="{Binding UserCanSeeCommand}"
                               BackgroundColor="#2ECC71"
                               TextColor="White"
                               FontSize="18"
                               HeightRequest="60"
                               CornerRadius="30"/>

                        <Button Text="🔊 No, I cannot see"
                               Command="{Binding UserCannotSeeCommand}"
                               BackgroundColor="#E74C3C"
                               TextColor="White"
                               FontSize="18"
                               HeightRequest="60"
                               CornerRadius="30"/>

                        <Label Text="If you cannot see, voice guidance will start automatically"
                               FontSize="12"
                               TextColor="#95A5A6"
                               HorizontalOptions="Center"
                               Margin="0,10,0,0"/>
                    </VerticalStackLayout>

                    <!-- Tap gesture for entire area -->
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding UserCanSeeCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Step 1: User Type Selection -->
                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        Padding="20"
                        IsVisible="{Binding CurrentStep, Converter={StaticResource EqualToConverter}, ConverterParameter=1}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="👤 Who are you?"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"
                               HorizontalOptions="Center"/>

                        <Label Text="Select your category"
                               FontSize="14"
                               TextColor="#7F8C8D"
                               HorizontalOptions="Center"/>

                        <Button Text="👴 Senior Citizen (60+)"
                               Command="{Binding SelectSeniorCommand}"
                               BackgroundColor="#3498DB"
                               TextColor="White"
                               FontSize="16"
                               HeightRequest="60"
                               CornerRadius="30"
                               Margin="0,10,0,0"/>

                        <Button Text="♿ Person with Disability"
                               Command="{Binding SelectPwdCommand}"
                               BackgroundColor="#9B59B6"
                               TextColor="White"
                               FontSize="16"
                               HeightRequest="60"
                               CornerRadius="30"/>

                        <Button Text="👴♿ Both"
                               Command="{Binding SelectBothCommand}"
                               BackgroundColor="#E67E22"
                               TextColor="White"
                               FontSize="16"
                               HeightRequest="60"
                               CornerRadius="30"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Step 2: PWD Category -->
                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        Padding="20"
                        IsVisible="{Binding CurrentStep, Converter={StaticResource EqualToConverter}, ConverterParameter=2}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="♿ Disability Type"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"
                               HorizontalOptions="Center"/>

                        <Label Text="What type of disability do you have?"
                               FontSize="14"
                               TextColor="#7F8C8D"
                               HorizontalOptions="Center"/>

                        <Button Text="👁️ Visual (Blind/Low Vision)"
                               Command="{Binding SelectPwdCategoryCommand}"
                               CommandParameter="Visual"
                               BackgroundColor="#E74C3C"
                               TextColor="White"
                               FontSize="14"
                               HeightRequest="50"
                               CornerRadius="25"/>

                        <Button Text="👂 Hearing (Deaf/Hard of Hearing)"
                               Command="{Binding SelectPwdCategoryCommand}"
                               CommandParameter="Hearing"
                               BackgroundColor="#F39C12"
                               TextColor="White"
                               FontSize="14"
                               HeightRequest="50"
                               CornerRadius="25"/>

                        <Button Text="🦽 Mobility (Wheelchair/Crutches)"
                               Command="{Binding SelectPwdCategoryCommand}"
                               CommandParameter="Mobility"
                               BackgroundColor="#3498DB"
                               TextColor="White"
                               FontSize="14"
                               HeightRequest="50"
                               CornerRadius="25"/>

                        <Button Text="🧠 Cognitive (Intellectual)"
                               Command="{Binding SelectPwdCategoryCommand}"
                               CommandParameter="Cognitive"
                               BackgroundColor="#9B59B6"
                               TextColor="White"
                               FontSize="14"
                               HeightRequest="50"
                               CornerRadius="25"/>

                        <Button Text="💭 Psychosocial (Mental Health)"
                               Command="{Binding SelectPwdCategoryCommand}"
                               CommandParameter="Psychosocial"
                               BackgroundColor="#1ABC9C"
                               TextColor="White"
                               FontSize="14"
                               HeightRequest="50"
                               CornerRadius="25"/>

                        <Button Text="🔄 Multiple Disabilities"
                               Command="{Binding SelectPwdCategoryCommand}"
                               CommandParameter="Multiple"
                               BackgroundColor="#34495E"
                               TextColor="White"
                               FontSize="14"
                               HeightRequest="50"
                               CornerRadius="25"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Step 3: Personal Information -->
                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        Padding="20"
                        IsVisible="{Binding CurrentStep, Converter={StaticResource EqualToConverter}, ConverterParameter=3}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="📝 Personal Information"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"
                               HorizontalOptions="Center"/>

                        <Label Text="Full Name"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"/>
                        <Entry Text="{Binding FullName}"
                              Placeholder="Enter your full name"
                              FontSize="16"
                              HeightRequest="50"/>

                        <Label Text="Phone Number"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"
                               Margin="0,10,0,0"/>
                        <Entry Text="{Binding PhoneNumber}"
                              Placeholder="+639171234567"
                              Keyboard="Telephone"
                              FontSize="16"
                              HeightRequest="50"/>

                        <Label Text="Date of Birth"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"
                               Margin="0,10,0,0"/>
                        <DatePicker Date="{Binding DateOfBirth}"
                                   FontSize="16"
                                   HeightRequest="50"/>

                        <Label Text="Guardian Information (Optional)"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"
                               Margin="0,20,0,0"/>

                        <Label Text="Guardian Name"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#7F8C8D"/>
                        <Entry Text="{Binding GuardianName}"
                              Placeholder="Guardian's full name"
                              FontSize="16"
                              HeightRequest="50"/>

                        <Label Text="Guardian Phone"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#7F8C8D"/>
                        <Entry Text="{Binding GuardianPhone}"
                              Placeholder="+639171234567"
                              Keyboard="Telephone"
                              FontSize="16"
                              HeightRequest="50"/>

                        <Button Text="Continue to Voice Registration →"
                               Command="{Binding ContinueToVoiceRegistrationCommand}"
                               BackgroundColor="#2ECC71"
                               TextColor="White"
                               FontSize="16"
                               HeightRequest="60"
                               CornerRadius="30"
                               Margin="0,20,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Step 4: Voice Registration -->
                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        Padding="20"
                        IsVisible="{Binding CurrentStep, Converter={StaticResource EqualToConverter}, ConverterParameter=4}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="🎤 Voice Registration"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2C3E50"
                               HorizontalOptions="Center"/>

                        <Label Text="{Binding RecordingInstruction}"
                               FontSize="16"
                               TextColor="#7F8C8D"
                               HorizontalOptions="Center"/>

                        <Label Text="Recording in progress..."
                               FontSize="14"
                               TextColor="#E74C3C"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               IsVisible="{Binding IsRecording}"/>

                        <ActivityIndicator IsRunning="{Binding IsRecording}"
                                         Color="#2ECC71"
                                         WidthRequest="60"
                                         HeightRequest="60"
                                         HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Step 5: Complete -->
                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        Padding="30"
                        IsVisible="{Binding CurrentStep, Converter={StaticResource EqualToConverter}, ConverterParameter=5}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="20">
                        <Label Text="✅"
                               FontSize="72"
                               HorizontalOptions="Center"/>

                        <Label Text="Registration Complete!"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#2ECC71"
                               HorizontalOptions="Center"/>

                        <Label Text="Welcome to Boses!"
                               FontSize="18"
                               TextColor="#2C3E50"
                               HorizontalOptions="Center"/>

                        <Label Text="Your voice has been registered and your profile is ready."
                               FontSize="14"
                               TextColor="#7F8C8D"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Status Message -->
        <Border Grid.Row="2"
                BackgroundColor="#3498DB"
                Stroke="#2980B9"
                StrokeThickness="1"
                Padding="15"
                Margin="0,10,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>

            <Label Text="{Binding StatusMessage}"
                   FontSize="14"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
             BackgroundColor="#80000000"
             IsVisible="{Binding IsBusy}">
            <VerticalStackLayout HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                 Color="White"
                                 WidthRequest="60"
                                 HeightRequest="60"/>
                <Label Text="{Binding StatusMessage}"
                      TextColor="White"
                      FontSize="14"
                      HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BosesApp.Presentation.ViewModels"
             x:Class="BosesApp.Presentation.Views.LanguageSelectionPage"
             x:DataType="viewmodels:LanguageSelectionViewModel"
             BackgroundColor="#F5F5F5"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,40,0,20">
            <Image Source="dotnet_bot.png"
                   HeightRequest="80"
                   WidthRequest="80"
                   HorizontalOptions="Center"/>

            <Label Text="Boses"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2196F3"/>

            <Label Text="Choose Your Language / Pumili ng Wika"
                   FontSize="18"
                   HorizontalOptions="Center"
                   TextColor="#666666"
                   Margin="0,10,0,0"/>
        </VerticalStackLayout>

        <!-- Language Options -->
        <VerticalStackLayout Grid.Row="1"
                            Spacing="20"
                            VerticalOptions="Center"
                            Margin="0,20">

            <!-- English Option -->
            <Border BackgroundColor="{Binding IsEnglishSelected, Converter={StaticResource BoolToColorConverter}}"
                    Stroke="{Binding IsEnglishSelected, Converter={StaticResource BoolToStrokeConverter}}"
                    StrokeThickness="3"
                    Padding="0"
                    HeightRequest="120">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectEnglishCommand}"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" Padding="20">
                    <!-- Flag Icon -->
                    <Label Grid.Column="0"
                           Text="🇺🇸"
                           FontSize="48"
                           VerticalOptions="Center"/>

                    <!-- Language Info -->
                    <VerticalStackLayout Grid.Column="1"
                                       Spacing="5"
                                       VerticalOptions="Center"
                                       Margin="20,0,0,0">
                        <Label Text="English"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#333333"/>
                        <Label Text="Use English language"
                               FontSize="14"
                               TextColor="#666666"/>
                    </VerticalStackLayout>

                    <!-- Selection Indicator -->
                    <Label Grid.Column="2"
                           Text="✓"
                           FontSize="32"
                           TextColor="#4CAF50"
                           VerticalOptions="Center"
                           IsVisible="{Binding IsEnglishSelected}"/>
                </Grid>
            </Border>

            <!-- Tagalog Option -->
            <Border BackgroundColor="{Binding IsTagalogSelected, Converter={StaticResource BoolToColorConverter}}"
                    Stroke="{Binding IsTagalogSelected, Converter={StaticResource BoolToStrokeConverter}}"
                    StrokeThickness="3"
                    Padding="0"
                    HeightRequest="120">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTagalogCommand}"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" Padding="20">
                    <!-- Flag Icon -->
                    <Label Grid.Column="0"
                           Text="🇵🇭"
                           FontSize="48"
                           VerticalOptions="Center"/>

                    <!-- Language Info -->
                    <VerticalStackLayout Grid.Column="1"
                                       Spacing="5"
                                       VerticalOptions="Center"
                                       Margin="20,0,0,0">
                        <Label Text="Tagalog"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#333333"/>
                        <Label Text="Gumamit ng wikang Tagalog"
                               FontSize="14"
                               TextColor="#666666"/>
                    </VerticalStackLayout>

                    <!-- Selection Indicator -->
                    <Label Grid.Column="2"
                           Text="✓"
                           FontSize="32"
                           TextColor="#4CAF50"
                           VerticalOptions="Center"
                           IsVisible="{Binding IsTagalogSelected}"/>
                </Grid>
            </Border>

            <!-- Voice Instruction -->
            <Label Text="🎤 You can also say 'English' or 'Tagalog'"
                   FontSize="14"
                   TextColor="#999999"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0"/>
        </VerticalStackLayout>

        <!-- Continue Button -->
        <Button Grid.Row="2"
                Text="Continue / Magpatuloy"
                Command="{Binding ContinueCommand}"
                BackgroundColor="#2196F3"
                TextColor="White"
                FontSize="18"
                FontAttributes="Bold"
                HeightRequest="60"
                CornerRadius="30"
                Margin="0,20,0,20"/>
    </Grid>
</ContentPage>

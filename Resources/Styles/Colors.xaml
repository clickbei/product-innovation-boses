<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Boses Brand Colors -->
    <Color x:Key="Primary">#2ECC71</Color>
    <Color x:Key="Secondary">#3498DB</Color>
    <Color x:Key="Tertiary">#E67E22</Color>
    <Color x:Key="Danger">#E74C3C</Color>
    <Color x:Key="Warning">#F39C12</Color>
    <Color x:Key="Success">#27AE60</Color>

    <!-- Neutral Colors -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#E0E0E0</Color>
    <Color x:Key="Gray300">#BDBDBD</Color>
    <Color x:Key="Gray400">#9E9E9E</Color>
    <Color x:Key="Gray500">#757575</Color>
    <Color x:Key="Gray600">#616161</Color>
    <Color x:Key="Gray900">#212121</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#2C3E50</Color>
    <Color x:Key="TextSecondary">#7F8C8D</Color>
    <Color x:Key="TextTertiary">#95A5A6</Color>

    <!-- Background Colors -->
    <Color x:Key="BackgroundLight">#F5F5F5</Color>
    <Color x:Key="BackgroundWhite">White</Color>
    <Color x:Key="BackgroundDark">#2C3E50</Color>

</ResourceDictionary>

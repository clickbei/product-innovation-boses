## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/

# macOS
.DS_Store

# SQLite databases
*.db
*.db-shm
*.db-wal

# JSON data files (if using fallback)
users.json

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# MAUI specific
**/AppPackages/
**/BundleArtifacts/
**/Package.StoreAssociation.xml
**/obj/
**/bin/

# Android
*.apk
*.aab
*.dex
*.ap_
*.class

# iOS
*.ipa
*.dSYM.zip
*.dSYM

# Windows
*.appx
*.appxbundle
*.msix
*.msixbundle

# Temporary files
*.tmp
*.temp
*.log
*.cache

# Backup files
*.bak
*~

# Local secrets — never commit these files
*Secrets.cs

# Helper scripts that may contain sensitive info
fix-secret.ps1



